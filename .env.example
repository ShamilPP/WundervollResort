# ─── Database ───────────────────────────────────────────────────
# Local standalone MongoDB (Phase 1 only — transactions won't work)
DATABASE_URL="mongodb://127.0.0.1:27017/wundervoll"

# For booking race-safety (Phase 5+), switch to Atlas or Docker replica-set:
# DATABASE_URL="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/wundervoll?retryWrites=true&w=majority"

# ─── NextAuth ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional for Phase 1 — credentials login works without it)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Added in later phases ──────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# CLOUDINARY_URL=""
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# RESEND_API_KEY=""
